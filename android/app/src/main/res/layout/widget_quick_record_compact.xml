<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/quick_record_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:background="@drawable/widget_card_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="14dp">

    <FrameLayout
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:background="@drawable/widget_record_circle"
        android:padding="14dp">

        <ImageView
            android:id="@+id/quick_record_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/widget_quick_record_title"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="@android:color/white" />
    </FrameLayout>

    <TextView
        android:id="@+id/quick_record_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/widget_quick_record_title"
        android:textColor="@color/widget_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/quick_record_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/widget_quick_record_subtitle"
        android:textColor="@color/widget_text_secondary"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/quick_record_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="@string/widget_quick_record_hint"
        android:textColor="@color/widget_text_secondary"
        android:textSize="10sp" />

</LinearLayout>