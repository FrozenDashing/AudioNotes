<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/todo_summary_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:background="@drawable/widget_card_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/widget_todo_summary_title"
            android:src="@android:drawable/ic_menu_agenda"
            android:tint="@color/widget_brand" />

        <TextView
            android:id="@+id/todo_summary_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/widget_todo_summary_title"
            android:textColor="@color/widget_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/todo_summary_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:background="@drawable/widget_chip_background"
            android:paddingLeft="10dp"
            android:paddingTop="5dp"
            android:paddingRight="10dp"
            android:paddingBottom="5dp"
            android:text="暂无更新"
            android:textColor="@color/widget_brand"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/todo_summary_open_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="4dp"
            android:paddingTop="4dp"
            android:paddingRight="4dp"
            android:paddingBottom="4dp"
            android:text="@string/widget_todo_open_app"
            android:textColor="@color/widget_brand"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/widget_chip_background"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="总计"
            android:textAlignment="center"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/todo_summary_total"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/widget_chip_background"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="0"
            android:textAlignment="center"
            android:textColor="@color/widget_brand"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/widget_chip_background"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="已完成"
            android:textAlignment="center"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp" />

        <TextView
